{% extends 'layouts.base' %}

{% block title %}
    {{ room.room_name }}
    - 清算アプリ
{% endblock %}

{% block content %}
    <div class="min-h-screen pb-32">
        {{ include('components.room.header') }}

        <div
            class="max-w-5xl mx-auto p-4 space-y-4 lg:space-y-0 lg:grid lg:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] lg:gap-6 lg:items-start"
        >
            <div class="space-y-4">
                {{ include('components.room.members') }}
                <div class="flex flex-col justify-center gap-4">
                    {{ include('components.room.forms') }}
                    {{ include('components.room.settlement_link') }}
                </div>
            </div>
            <div>
                {{ include('components.room.items') }}
            </div>
        </div>

        {{ include('components.room.ranking_bar') }}
    </div>
{% endblock %}
