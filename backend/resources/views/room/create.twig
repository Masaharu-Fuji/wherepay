{% extends 'layouts.base' %}

{% block title %}
    ルーム作成 - 清算アプリ
{% endblock %}

{% block content %}
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl border border-gray-200 shadow-xl p-8">
            <h2 class="text-center mb-6 text-2xl">ルーム作成</h2>

            <form
                method="POST"
                action="{{ route('rooms.store') }}"
                class="space-y-6"
            >
                <input type="hidden" name="_token" value="{{ csrf_token() }}" />

                <div class="flex flex-col gap-1">
                    <label
                        for="room_name"
                        class="block mb-1 text-gray-700 text-xs md:text-sm"
                    >
                        グループ名を入力してください
                    </label>
                    <input
                        id="room_name"
                        name="room_name"
                        type="text"
                        placeholder="例: 飲み会グループ"
                        value="{{ old('room_name') }}"
                        class="{{
                        cn(
                            'w-full text-sm md:text-sm p-2',
                            'border-2 border-gray-200 rounded-xl',
                            'focus:outline-none focus:border-blue-500',
                            'focus:ring-4 focus:ring-blue-100',
                            'transition-all'
                        )
                        }}"
                        autofocus
                        required
                    />
                    {% if errors.has('room_name') %}
                        <p class="mt-2 text-sm text-red-600">
                            {{ errors.first('room_name') }}
                        </p>
                    {% endif %}
                </div>

                <button
                    type="submit"
                    class="{{
                    cn(
                        'w-full text-sm md:text-lg p-2',
                        'bg-gradient-to-r from-blue-500 to-purple-600 text-white',
                        'rounded-xl',
                        'hover:from-blue-600 hover:to-purple-700',
                        'disabled:opacity-50 disabled:cursor-not-allowed',
                        'transition-all shadow-lg hover:shadow-xl',
                        'transform hover:scale-[1.02] active:scale-[0.98]'
                    )
                    }}"
                >
                    ルームを作成 🚀
                </button>
            </form>

            <div class="mt-2 md:mt-4 pt-2 md:pt-4 border-t border-gray-200">
                <p class="text-sm text-gray-600 mb-3 text-center">
                    主な機能
                </p>
                <div class="space-y-2 text-sm text-gray-600">
                    <div class="flex items-center gap-2">
                        <span
                            class="{{
                            cn(
                                'w-6 h-6',
                                'bg-blue-100 rounded-full',
                                'flex items-center justify-center',
                                'text-blue-600'
                            )
                            }}"
                        >
                            ✓
                        </span>
                        <span>メンバー管理と支払い記録</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span
                            class="{{
                            cn(
                                'w-6 h-6',
                                'bg-purple-100 rounded-full',
                                'flex items-center justify-center',
                                'text-purple-600'
                            )
                            }}"
                        >
                            ✓
                        </span>
                        <span>自動清算計算とおつり計算</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <span
                            class="{{
                            cn(
                                'w-6 h-6',
                                'bg-pink-100 rounded-full',
                                'flex items-center justify-center',
                                'text-pink-600'
                            )
                            }}"
                        >
                            ✓
                        </span>
                        <span>位置情報で思い出を記録</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
