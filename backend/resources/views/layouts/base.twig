<!DOCTYPE html>
<html lang="ja">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=BIZ+UDPMincho&family=Noto+Sans+JP:wght@100..900&display=swap"
            rel="stylesheet"
        />
        <title>
            {% block title %}
                清算アプリ
            {% endblock %}
        </title>
        {{ vite(['resources/css/app.css', 'resources/js/app.js']) }}
    </head>
    <body
        class="{{
        cn(
            'min-h-screen bg-gradient-to-br from-primary-50 via-sub-green-50 to-sub-pink-50'
        )
        }}"
        style="{{
        cn(
            'font-family: "Noto Sans JP", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif'
        )
        }}"
    >
        {% block content %}

        {% endblock %}

        <script src="/js/location.js"></script>
        <script src="/js/ranking_bar.js"></script>
        <script src="/js/settlement_accordion.js"></script>
        <script src="/js/toast.js"></script>
        <script src="/js/room_header.js"></script>
        <script src="/js/room_items_height.js"></script>
    </body>
</html>
