{% if (locatedItems|length) > 0 %}
    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
        <div class="flex items-center gap-2 mb-6">
            <span class="text-2xl">📍</span>
            <h3 class="text-xl">訪れた場所</h3>
            <span
                class="ml-auto bg-green-100 text-green-800 px-3 py-1 rounded-full text-sm"
            >
                {{ locatedItems|length }}ヶ所
            </span>
            {% if allLocationsUrl %}
                <a
                    href="{{ allLocationsUrl }}"
                    target="_blank"
                    class="{{
                    cn(
                        'block text-center text-lg py-2 px-2',
                        'bg-gradient-to-r from-red-500 to-orange-500 text-white',
                        'rounded-xl',
                        'hover:from-red-600 hover:to-orange-600',
                        'shadow-lg hover:shadow-xl',
                        'transition-all transform hover:scale-[1.02]'
                    )
                    }}"
                >
                    🚶 経路と全地点を表示
                </a>
            {% endif %}
        </div>

        <div class="grid grid-cols-2 gap-3 lg:grid-cols-3">
            {% for item in locatedItems %}
                {% set payer = item.payer %}
                <div
                    class="{{
                    cn(
                        'p-3',
                        'bg-gradient-to-r from-green-50 to-blue-50',
                        'rounded-lg border border-green-200',
                        'hover:shadow-md transition-all',
                        'h-full'
                    )
                    }}"
                >
                    <div class="flex items-start gap-2">
                        <div
                            class="{{
                            cn(
                                'shrink-0 w-7 h-7',
                                'bg-gradient-to-r from-red-500 to-orange-500 text-white',
                                'rounded-full border border-red-300 bg-white',
                                'flex items-center justify-center',
                                'text-xs font-semibold text-red-500',
                                'shadow-sm'
                            )
                            }}"
                        >
                            {{ loop.index }}
                        </div>
                        <div class="flex-1">
                            <div class="mb-0.5">
                                <span class="text-sm font-medium">
                                    {{ item.item_name }}
                                </span>
                            </div>
                            <div
                                class="flex flex-col items-start gap-1 text-xs text-gray-600 m-0"
                            >
                                <span>
                                    💴 ¥{{ item.amount|number_format(0, '.', ',') }}
                                </span>
                                <span>
                                    👤
                                    {{ payer ? payer.member_name : '不明' }}
                                </span>
                            </div>
                            <div
                                class="text-[10px] text-gray-500 leading-tight"
                            >
                                📌
                                {{ item.location.latitude }}, {{ item.location.longitude }}
                            </div>
                        </div>
                        {% if
                            item.location
                                and item.location.latitude is not null
                                and item.location.longitude is not null %}
                            {% set mapUrl = 'https://www.google.com/maps/search/?api=1&query='
                                ~ item.location.latitude
                                ~ ','
                                ~ item.location.longitude
                            %}
                            <a
                                href="{{ mapUrl }}"
                                target="_blank"
                                class="{{
                                cn(
                                    'shrink-0 px-2 py-1',
                                    'bg-gradient-to-r from-blue-500 to-blue-600 text-white',
                                    'rounded-md',
                                    'hover:from-blue-600 hover:to-blue-700',
                                    'shadow-sm hover:shadow-md',
                                    'transition-all text-[11px] whitespace-nowrap'
                                )
                                }}"
                            >
                                🗺️ 地図
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
