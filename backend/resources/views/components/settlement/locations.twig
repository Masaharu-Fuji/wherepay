{% if (locatedItems|length) > 0 %}
    <div
        class="bg-white rounded-2xl border border-gray-200 shadow-lg p-4 md:p-6"
    >
        <div class="flex items-center gap-1 mb-4 md:mb-6">
            <span class="icon-[fluent-color--location-ripple-24] w-10 h-10">

            </span>
            <h3 class="text-sm md:text-xl">訪れた場所</h3>
            <span
                class="ml-auto {{
                cn(
                    'bg-sub-green text-white px-3 py-0.5',
                    'rounded-full text-xs md:text-sm',
                    'flex items-center justify-center gap-1'
                )
                }}"
            >
                {{ locatedItems|length }}ヶ所
            </span>
            {% if allLocationsUrl %}
                <a
                    href="{{ allLocationsUrl }}"
                    target="_blank"
                    class="{{
                    cn(
                        'ml-2 text-xs md:text-sm lg:text-base py-1 px-2 md:py-1.5 md:px-2',
                        'bg-gradient-to-r from-sub-pink to-sub-pink-hover text-white',
                        'rounded-xl',
                        'hover:opacity-90',
                        'shadow-lg hover:shadow-xl',
                        'transition-all transform hover:scale-[1.02]',
                        'flex items-center justify-center gap-1'
                    )
                    }}"
                >
                    <span class="icon-[fluent-color--globe-24] w-5 h-5"></span>
                    <span class="hidden sm:inline">経路表示</span>
                </a>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 lg:grid-cols-3">
            {% for item in locatedItems %}
                {% set payer = item.payer %}
                <div
                    class="{{
                    cn(
                        'flex flex-col gap-2 p-2 md:p-3',
                        'bg-gradient-to-r from-sub-green-50 to-primary-50',
                        'rounded-lg border border-sub-green-200',
                        'hover:shadow-md transition-all',
                        'h-full'
                    )
                    }}"
                >
                    <div class="flex items-start gap-2">
                        <div
                            class="{{
                            cn(
                                'shrink-0 w-7 h-7',
                                'bg-gradient-to-r from-sub-yellow to-sub-yellow-hover text-white',
                                'rounded-full border border-sub-yellow-200 bg-white',
                                'flex items-center justify-center',
                                'text-xs font-semibold text-gray-900',
                                'shadow-sm'
                            )
                            }}"
                        >
                            {{ loop.index }}
                        </div>
                        <div class="flex-1">
                            <div class="mb-0.5">
                                <span class="text-sm font-medium">
                                    {{ item.item_name }}
                                </span>
                            </div>
                        </div>
                        {% if
                            item.location
                                and item.location.latitude is not null
                                and item.location.longitude is not null %}
                            {% set mapUrl = 'https://www.google.com/maps/search/?api=1&query='
                                ~ item.location.latitude
                                ~ ','
                                ~ item.location.longitude
                            %}
                            <a
                                href="{{ mapUrl }}"
                                target="_blank"
                                class="{{
                                cn(
                                    'shrink-0 px-2 py-1 flex items-center gap-1',
                                    'bg-primary text-white',
                                    'rounded-md',
                                    'hover:opacity-90',
                                    'shadow-sm hover:shadow-md',
                                    'transition-all text-[11px] whitespace-nowrap'
                                )
                                }}"
                            >
                                <span
                                    class="icon-[fluent-color--beach-32] w-5 h-5"
                                >

                                </span>
                                <span class="hidden sm:inline">地図</span>
                            </a>
                        {% endif %}
                    </div>
                    <div
                        class="flex flex-col items-start gap-1 text-xs text-gray-600 m-0"
                    >
                        <div class="flex items-center gap-1">
                            <span
                                class="icon-[fluent-color--premium-24] w-5 h-5"
                            >

                            </span>
                            <span class="text-sm">
                                ¥{{ item.amount|number_format(0, '.', ',') }}
                            </span>
                        </div>
                        <div class="flex items-center gap-1">
                            <span
                                class="icon-[fluent-color--person-24] w-5 h-5"
                            >

                            </span>
                            <span class="text-sm">
                                {{ payer ? payer.member_name : '不明' }}
                            </span>
                        </div>
                        <div
                            class="text-[10px] text-gray-500 leading-tight flex items-center gap-1"
                        >
                            <span class="icon-[fluent-color--pin-24] w-5 h-5">

                            </span>
                            <span class="text-sm">
                                {{ item.location.latitude }}, {{
                                    item.location.longitude
                                }}
                            </span>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
