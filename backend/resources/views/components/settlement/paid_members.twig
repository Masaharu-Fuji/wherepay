{% if (paidMembers|length) > 0 %}
    <div
        class="bg-white rounded-2xl border border-sub-green-200 shadow-md p-4 md:p-5"
    >
        <div class="flex items-center gap-2 mb-2 md:mb-3">
            <span class="icon-[fluent-color--checkmark-circle-24] w-10 h-10">

            </span>
            <h3 class="text-lg font-semibold text-sub-green">清算完了</h3>
            <span
                class="ml-auto text-[11px] md:text-xs bg-sub-green text-white px-2 py-0.5 rounded-full"
            >
                {{ paidMembers|length }}人
            </span>
        </div>
        <div class="flex flex-wrap gap-1.5 md:gap-2">
            {% for member in paidMembers %}
                <div
                    class="px-3 py-1 rounded-full bg-sub-green text-white text-xs md:text-sm"
                >
                    {{ member.id }} {{ member.member_name }}
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
