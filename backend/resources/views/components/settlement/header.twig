<div class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
    <div class="max-w-4xl mx-auto px-2 md:px-3 py-2 md:py-3">
        <div class="flex gap-2 md:gap-3 items-center">
            <a
                href="{{
                route(
                    'rooms.show',
                    {
                        room: room.id,
                        query_key: query_key
                    }
                )
                }}"
                class="{{
                cn(
                    'p-2',
                    'hover:bg-gray-100',
                    'rounded-md',
                    'transition-colors'
                )
                }}"
            >
                戻る
            </a>
            <div class="flex gap-2 md:gap-3 items-center flex-wrap">
                <h1 class="font-bold text-xs md:text-xl">清算結果</h1>
                <a
                    href="{{
                    route(
                        'rooms.settlement.csv',
                        {
                            room: room.id,
                            query_key: query_key
                        }
                    )
                    }}"
                    class="{{
                    cn(
                        'px-3 py-2 rounded-lg',
                        'bg-sub-green hover:bg-sub-green-hover',
                        'text-white text-sm font-medium',
                        'transition-colors'
                    )
                    }}"
                >
                    CSV出力
                </a>
                {% if (transactions|length) > 0 %}
                    <form
                        method="POST"
                        action="{{
                        route(
                            'rooms.settlement.confirm',
                            {
                                room: room.id
                            }
                        )
                        }}"
                    >
                        <input
                            type="hidden"
                            name="_token"
                            value="{{ csrf_token() }}"
                        />
                        <button
                            type="button"
                            data-settlement-confirm
                            data-is-fully-settled="{{
                            isFullySettled
                                ? '1'
                                : '0'
                            }}"
                            data-has-paid-members="{{
                            (paidMembers|length) > 0
                                ? '1'
                                : '0'
                            }}"
                            class="{{
                            cn(
                                'px-4 py-2 rounded-lg',
                                'bg-primary hover:bg-primary-hover',
                                'text-white text-sm font-medium',
                                'shadow-md',
                                'hover:opacity-90',
                                'transition-all'
                            )
                            }}"
                        >
                            清算を確定して保存
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>
