<div class="bg-white border-b border-gray-200 sticky top-0 z-10 shadow-sm">
    <div class="max-w-4xl mx-auto p-4">
        <div class="flex items-center gap-4">
            <a
                href="{{
                route(
                    'rooms.show',
                    {
                        room: room.id
                    }
                )
                }}"
                class="{{
                cn(
                    'p-2',
                    'hover:bg-gray-100',
                    'rounded-lg',
                    'transition-colors'
                )
                }}"
            >
                ← 戻る
            </a>
            <div class="flex-1 flex items-center justify-between gap-4">
                <h1 class="text-2xl">💰 清算結果</h1>
                {% if (transactions|length) > 0 %}
                    <form
                        method="POST"
                        action="{{
                        route(
                            'rooms.settlement.confirm',
                            {
                                room: room.id
                            }
                        )
                        }}"
                    >
                        <input
                            type="hidden"
                            name="_token"
                            value="{{ csrf_token() }}"
                        />
                        <button
                            type="button"
                            data-settlement-confirm
                            data-is-fully-settled="{{
                            isFullySettled
                                ? '1'
                                : '0'
                            }}"
                            class="{{
                            cn(
                                'px-4 py-2 rounded-lg',
                                'bg-gradient-to-r from-emerald-500 to-emerald-600',
                                'text-white text-sm font-medium',
                                'shadow-md',
                                'hover:from-emerald-600 hover:to-emerald-700',
                                'transition-all'
                            )
                            }}"
                        >
                            清算を確定して保存
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </div>
</div>
