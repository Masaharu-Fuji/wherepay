<div
    class="{{
    cn(
        'flex justify-evenly',
        'bg-gradient-to-br from-purple-500 to-pink-500',
        'rounded-2xl border border-purple-600',
        'shadow-xl p-8',
        'text-white'
    )
    }}"
>
    <div class="flex flex-col justify-center gap-4">
        <div class="text-center mb-3">
            <div class="text-5xl mb-2">
                💴
            </div>
            <h3 class="text-lg opacity-90">合計金額</h3>
        </div>
        <div class="text-center">
            <div class="text-5xl mb-4">
                ¥{{ total|number_format(0, '.', ',') }}
            </div>
        </div>
    </div>

    <div class="border-l border-white/30 pl-4">
        <div class="space-y-2 flex flex-col gap-2">
            {% for member in room.members %}
                {% set debt =
                    memberDebts[member.id]|default(0)|round(0, 'common')
                %}
                <div
                    class="flex justify-between items-center gap-2 bg-white/10 backdrop-blur-sm rounded-lg px-4 py-2"
                >
                    <span>{{ member.member_name }}</span>
                    <span>¥{{ debt|number_format(0, '.', ',') }}</span>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
