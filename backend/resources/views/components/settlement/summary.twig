<div
    class="{{
    cn(
        'flex flex-col gap-2 md:gap-6 lg:flex-row lg:justify-between',
        'bg-gradient-to-br from-purple-500 to-pink-500',
        'rounded-2xl border border-purple-600',
        'shadow-xl p-3 md:p-6',
        'text-white'
    )
    }}"
>
    <div class="flex flex-col justify-center gap-2 md:gap-3 lg:w-2/5">
        <div class="text-center mb-1 md:mb-3">
            <div class="text-2xl md:text-4xl mb-2">
                💴
            </div>
            <h3 class="text-base md:text-lg opacity-90">合計金額</h3>
        </div>
        <div class="text-center">
            <div class="text-2xl md:text-4xl mb-4">
                ¥{{ total|number_format(0, '.', ',') }}
            </div>
        </div>
    </div>

    <div class="flex flex-col gap-1 md:gap-2 lg:w-3/5">
        {% for member in room.members %}
            {% set debt =
                memberDebts[member.id]|default(0)|round(0, 'common')
            %}
            <div
                class="flex justify-between items-center gap-1 md:gap-2 bg-white/10 backdrop-blur-sm rounded-lg px-4 py-2"
            >
                <span class="text-sm md:text-base">
                    {{ member.member_name }}
                </span>
                <span class="text-sm md:text-base">
                    ¥{{ debt|number_format(0, '.', ',') }}
                </span>
            </div>
        {% endfor %}
    </div>
</div>
