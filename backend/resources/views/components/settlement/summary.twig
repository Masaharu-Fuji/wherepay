<div
    class="{{
    cn(
        'flex flex-col gap-2 md:gap-6 lg:flex-row lg:justify-between',
        'bg-gradient-to-br from-primary to-sub-pink',
        'rounded-2xl border border-primary-200',
        'shadow-xl p-3 md:p-6',
        'text-white'
    )
    }}"
>
    <div
        class="{{
        cn(
            'flex md:flex-col items-center justify-center',
            'px-2 py-2 gap-2 md:gap-3',
            'lg:w-2/5'
        )
        }}"
    >
        <span class="icon-[fluent-color--premium-24] w-10 h-10"></span>
        <h3 class="text-base md:text-lg opacity-90">合計金額</h3>
        <span class="text-2xl md:text-4xl">
            ¥{{ total|number_format(0, '.', ',') }}
        </span>
    </div>

    <div class="flex flex-col gap-1 md:gap-2 lg:w-3/5">
        {% for member in room.members %}
            {% set debt =
                memberDebts[member.id]|default(0)|round(0, 'common')
            %}
            <div
                class="{{
                cn(
                    'flex justify-between items-center gap-1 md:gap-2',
                    'bg-white/10 backdrop-blur-sm rounded-lg px-4 py-2'
                )
                }}"
            >
                <span class="text-sm md:text-base">
                    {{ member.id }} {{ member.member_name }}
                </span>
                <span class="text-sm md:text-base">
                    ¥{{ debt|number_format(0, '.', ',') }}
                </span>
            </div>
        {% endfor %}
    </div>
</div>
