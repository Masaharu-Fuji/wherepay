<div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
    <div class="flex items-center gap-2 mb-6">
        <span class="text-2xl">💵</span>
        <h3 class="text-xl">おつり計算</h3>
    </div>
    <form
        method="POST"
        action="{{
        route(
            'rooms.settlement.show',
            {
                room: room.id
            }
        )
        }}"
        class="space-y-5"
    >
        <input type="hidden" name="_token" value="{{ csrf_token() }}" />

        {% for member in room.members %}
            {% set owed = 0 %}
            {% for t in transactions %}
                {% if t.from == member.id %}
                    {% set owed = owed + t.amount %}
                {% endif %}
            {% endfor %}

            {% if owed != 0 %}
                {% set change = changeByMember[member.id]|default(null) %}

                <div
                    class="{{
                    cn(
                        'space-y-3 p-4',
                        'bg-gradient-to-r from-gray-50 to-blue-50',
                        'rounded-xl border border-gray-200'
                    )
                    }}"
                >
                    <div class="flex items-center justify-between">
                        <label for="cash-{{ member.id }}" class="text-gray-700">
                            {{ member.member_name }}
                        </label>
                        <div class="flex items-center gap-2">
                            {% if change is not null and change >= 0 %}
                                <span
                                    class="text-xs bg-green-100 text-green-800 px-2 py-1 rounded-full"
                                >
                                    清算完了
                                </span>
                            {% endif %}
                            <span
                                class="text-sm bg-purple-100 text-purple-800 px-3 py-1 rounded-full"
                            >
                                支払額: ¥{{ owed|number_format(0, '.', ',') }}
                            </span>
                        </div>
                        <input
                            id="cash-{{ member.id }}"
                            type="number"
                            name="cash[{{ member.id }}]"
                            placeholder="所持金を入力"
                            value="{{ cashInputs[member.id]|default('') }}"
                            class="{{
                            cn(
                                'w-1/2 text-lg p-2',
                                'border-2 border-gray-200 rounded-xl',
                                'focus:outline-none focus:border-purple-500',
                                'focus:ring-4 focus:ring-purple-100',
                                'transition-all'
                            )
                            }}"
                        />
                    </div>

                    {% if change is not null %}
                        {% set change_classes = change >= 0
                            ? [
                                'bg-gradient-to-r',
                                'from-green-50',
                                'to-emerald-50',
                                'border',
                                'border-green-200'
                            ]
                            : [
                                'bg-gradient-to-r',
                                'from-red-50',
                                'to-pink-50',
                                'border',
                                'border-red-200'
                            ]
                        %}
                        <div
                            class="{{
                            cn(
                                'mt-2 p-4 rounded-xl',
                                change_classes|join(' ')
                            )
                            }}"
                        >
                            {% if change >= 0 %}
                                <div class="flex items-center gap-2">
                                    <span class="text-2xl">✅</span>
                                    <span class="text-green-700 text-lg">
                                        おつり: ¥{{ change|round(0, 'common')|number_format(0, '.', ',') }}
                                    </span>
                                </div>
                            {% else %}
                                <div class="flex items-center gap-2">
                                    <span class="text-2xl">⚠️</span>
                                    <span class="text-red-700 text-lg">
                                        不足: ¥{{ (change * -1)|round(0, 'common')|number_format(0, '.', ',') }}
                                    </span>
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        {% endfor %}

        {% if (transactions|length) > 0 %}
            <button
                type="submit"
                class="{{
                cn(
                    'w-full text-lg py-4',
                    'bg-gradient-to-r from-purple-500 to-pink-600 text-white',
                    'rounded-xl',
                    'hover:from-purple-600 hover:to-pink-700',
                    'shadow-lg transition-all'
                )
                }}"
            >
                おつりを再計算
            </button>
        {% endif %}
    </form>
</div>
