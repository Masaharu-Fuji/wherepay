{% if (ranking|length) > 0 %}
    <div
        id="ranking-bar"
        class="{{
        cn(
            'fixed bottom-0 left-0 right-0',
            'bg-white border-t border-gray-200',
            'shadow-2xl',
            'transition-transform duration-300 ease-out',
            'translate-y-[calc(100%-3rem)]'
        )
        }}"
    >
        <div class="max-w-4xl mx-auto p-4">
            <div class="flex items-center justify-between gap-2 mb-3">
                <div class="flex items-center gap-2">
                    <span class="text-xl">🏆</span>
                    <h3>支払いランキング</h3>
                </div>
                <button
                    id="ranking-bar-toggle"
                    type="button"
                    class="flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700"
                >
                    <span data-open-text="閉じる" data-closed-text="開く">
                        開く
                    </span>
                    <span aria-hidden="true">︽</span>
                </button>
            </div>
            <div id="ranking-bar-content" class="space-y-2">
                {% for entry in ranking %}
                    {% set index = loop.index0 %}
                    {% set medalColors = [
                        'bg-gradient-to-r from-yellow-400 to-yellow-500 text-yellow-900',
                        'bg-gradient-to-r from-gray-300 to-gray-400 text-gray-800',
                        'bg-gradient-to-r from-orange-400 to-orange-500 text-orange-900'
                    ] %}
                    {% set defaultColor =
                        'bg-gradient-to-r from-blue-100 to-purple-100 text-blue-800'
                    %}
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div
                                class="{{
                                cn(
                                    'flex items-center justify-center',
                                    'w-8 h-8 rounded-full',
                                    medalColors[index] ?? defaultColor,
                                    'shadow-sm'
                                )
                                }}"
                            >
                                {{ loop.index }}
                            </div>
                            <span>{{ entry.member.member_name }}</span>
                        </div>
                        <span class="text-lg text-purple-600">
                            ¥{{ entry.total|number_format(0, '.', ',') }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}
