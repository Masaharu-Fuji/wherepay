{% if (ranking|length) > 0 %}
    <div
        id="ranking-bar"
        class="{{
        cn(
            'fixed bottom-0 left-0 right-0',
            'bg-white border-t border-gray-200',
            'shadow-2xl',
            'transition-transform duration-300 ease-out',
            'translate-y-[calc(100%-5rem)]'
        )
        }}"
    >
        <div class="max-w-4xl mx-auto p-4">
            <button
                id="ranking-bar-toggle"
                type="button"
                class="{{
                cn(
                    'w-full flex items-center justify-between gap-2',
                    'mb-3 py-2 -mx-1 px-1 rounded-lg text-left',
                    'hover:bg-gray-50 active:bg-gray-100 transition-colors',
                    'flex items-center justify-center gap-1'
                )
                }}"
            >
                <div class="flex items-center gap-2">
                    <span class="icon-[fluent-color--trophy-24] w-10 h-10">

                    </span>
                    <h3>支払いランキング</h3>
                </div>
                <span
                    class="text-sm text-gray-500"
                    data-open-text="閉じる"
                    data-closed-text="開く"
                >
                    開く
                </span>
            </button>
            <div id="ranking-bar-content" class="space-y-2">
                {% for entry in ranking %}
                    {% set index = loop.index0 %}
                    {% set medalColors = [
                        'bg-sub-yellow text-gray-900',
                        'bg-gray-600 text-white',
                        'bg-gray-700 text-white'
                    ] %}
                    {% set defaultColor = 'bg-primary text-white' %}
                    <div class="flex justify-between items-center">
                        <div class="flex items-center gap-3">
                            <div
                                class="{{
                                cn(
                                    'flex items-center justify-center',
                                    'w-8 h-8 rounded-full',
                                    medalColors[index] ?? defaultColor,
                                    'shadow-sm'
                                )
                                }}"
                            >
                                {{ loop.index }}
                            </div>
                            <span>{{ entry.member.member_name }}</span>
                        </div>
                        <span class="text-lg text-sub-pink">
                            ¥{{ entry.total|number_format(0, '.', ',') }}
                        </span>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endif %}
