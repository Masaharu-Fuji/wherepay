{% if (room.items|length) > 0 and (room.members|length) > 0 %}
    <a
        id="settlement-view-link"
        href="{{
        route(
            'rooms.settlement.show',
            {
                room: room.id,
                query_key: room.password_plan
            }
        )
        }}"
        class="{{
        cn(
            'block text-center text-sm md:text-xl py-3 md:py-5',
            'bg-gradient-to-r from-sub-green to-sub-green-hover text-white',
            'rounded-2xl',
            'hover:opacity-90',
            'shadow-lg hover:shadow-xl',
            'transition-all transform hover:scale-[1.02]',
            'flex items-center justify-center gap-1'
        )
        }}"
    >
        <span class="icon-[fluent-color--clipboard-task-24] w-10 h-10"></span>
        <span class="text-sm md:text-xl">清算結果を見る</span>
    </a>
{% endif %}
