<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div
        class="bg-white rounded-2xl border border-gray-200 shadow-lg p-2 md:p-6"
    >
        <div class="flex items-center gap-2 mb-4">
            <span class="icon-[fluent-color--person-add-20] w-10 h-10"></span>
            <h3 class="font-semibold">メンバー追加</h3>
        </div>
        <form
            method="POST"
            action="{{
            route(
                'rooms.members.store',
                {
                    room: room.id
                }
            )
            }}"
            class="space-y-4"
        >
            <input type="hidden" name="_token" value="{{ csrf_token() }}" />
            <div>
                <label
                    for="member_name"
                    class="block text-xs md:text-sm mb-2 text-gray-700"
                >
                    メンバー名
                </label>
                <input
                    id="member_name"
                    name="member_name"
                    placeholder="名前を入力"
                    value="{{ old('member_name') }}"
                    class="{{
                    cn(
                        'w-full text-sm md:text-lg p-2',
                        'border-2 border-gray-200 rounded-xl',
                        'focus:outline-none focus:border-primary',
                        'focus:ring-4 focus:ring-primary-100',
                        'transition-all'
                    )
                    }}"
                    required
                />
                {% if errors.has('member_name') %}
                    <p class="mt-2 text-sm text-sub-pink">
                        {{ errors.first('member_name') }}
                    </p>
                {% endif %}
            </div>
            <button
                type="submit"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'bg-gradient-to-r from-primary to-sub-pink text-white',
                    'rounded-xl',
                    'hover:from-primary-hover hover:to-sub-pink-hover',
                    'shadow-lg transition-all',
                    'flex items-center justify-center gap-1'
                )
                }}"
            >
                <span class="icon-[fluent-color--person-add-24] w-10 h-10">

                </span>
                <span class="text-sm md:text-xl">追加</span>
            </button>
        </form>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
        {% if (room.members|length) > 0 %}
            <div class="flex items-center gap-2 mb-4">
                <span class="icon-[fluent-color--people-list-20] w-10 h-10">

                </span>
                <h3>一覧</h3>
                <span
                    class="ml-auto bg-primary text-white px-3 py-1 rounded-full text-sm"
                >
                    {{ room.members|length }}人
                </span>
            </div>
            <div class="flex flex-wrap gap-2">
                {% for member in room.members %}
                    <div
                        class="{{
                        cn(
                            'px-4 py-2',
                            'bg-primary text-white',
                            'rounded-full'
                        )
                        }}"
                    >
                        {{ member.member_name }}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-500 text-sm">
                まだメンバーがいません。左のフォームから追加してください。
            </p>
        {% endif %}
    </div>
</div>
