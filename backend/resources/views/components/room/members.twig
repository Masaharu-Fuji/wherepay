<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
        <div class="flex items-center gap-2 mb-4">
            <span class="text-2xl">👥</span>
            <h3 class="font-semibold">メンバー追加</h3>
        </div>
        <form
            method="POST"
            action="{{
            route(
                'rooms.members.store',
                {
                    room: room.id
                }
            )
            }}"
            class="space-y-4"
        >
            <input type="hidden" name="_token" value="{{ csrf_token() }}" />
            <div>
                <label for="member_name" class="block mb-2 text-gray-700">
                    メンバー名
                </label>
                <input
                    id="member_name"
                    name="member_name"
                    placeholder="名前を入力"
                    value="{{ old('member_name') }}"
                    class="{{
                    cn(
                        'w-full text-lg p-3',
                        'border-2 border-gray-200 rounded-xl',
                        'focus:outline-none focus:border-blue-500',
                        'focus:ring-4 focus:ring-blue-100',
                        'transition-all'
                    )
                    }}"
                    required
                />
                {% if errors.has('member_name') %}
                    <p class="mt-2 text-sm text-red-600">
                        {{ errors.first('member_name') }}
                    </p>
                {% endif %}
            </div>
            <button
                type="submit"
                class="{{
                cn(
                    'w-full text-lg py-3',
                    'bg-gradient-to-r from-blue-500 to-purple-600 text-white',
                    'rounded-xl',
                    'hover:from-blue-600 hover:to-purple-700',
                    'shadow-lg transition-all'
                )
                }}"
            >
                追加
            </button>
        </form>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
        {% if (room.members|length) > 0 %}
            <div class="flex items-center gap-2 mb-4">
                <span class="text-2xl">👥</span>
                <h3>メンバー一覧</h3>
                <span
                    class="ml-auto bg-blue-100 text-blue-800 px-3 py-1 rounded-full text-sm"
                >
                    {{ room.members|length }}人
                </span>
            </div>
            <div class="flex flex-wrap gap-2">
                {% for member in room.members %}
                    <div
                        class="{{
                        cn(
                            'px-4 py-2',
                            'bg-gradient-to-r from-blue-100 to-purple-100',
                            'text-blue-900',
                            'rounded-full border border-blue-200'
                        )
                        }}"
                    >
                        {{ member.member_name }}
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <p class="text-gray-500 text-sm">
                まだメンバーがいません。左のフォームから追加してください。
            </p>
        {% endif %}
    </div>
</div>
