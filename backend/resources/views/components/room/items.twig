<div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-2 md:p-6">
    <div class="flex justify-start items-center gap-2 mb-4">
        <span class="icon-[fluent-color--gift-24] w-10 h-10"></span>
        <h3 class="text-xs md:text-sm font-bold">品目一覧</h3>
        <span class="bg-sub-pink text-white px-3 py-1 rounded-full text-sm">
            {{ room.items|length }}件
        </span>
    </div>

    {% if (room.items|length) == 0 %}
        <div class="text-center py-12">
            <span class="icon-[fluent-color--drafts-24] w-10 h-10"></span>
            <p class="text-gray-500 text-sm font-bold">
                品目を追加してください
            </p>
        </div>
    {% else %}
        <div
            id="room-items-scroll"
            class="space-y-2 md:space-y-3 md:overflow-y-auto"
        >
            {% for item in room.items %}
                {% set payer = item.payer %}
                {% set recipients = [] %}
                {% for participant in item.participants %}
                    {% if participant.member %}
                        {% set recipients =
                            recipients|merge([participant.member.member_name])
                        %}
                    {% endif %}
                {% endfor %}
                <div
                    class="{{
                    cn(
                        'p-3 md:p-4',
                        'bg-gradient-to-r from-gray-50 to-sub-pink-50',
                        'rounded-xl border border-gray-200',
                        'hover:shadow-md transition-shadow'
                    )
                    }}"
                >
                    <div
                        class="flex flex-col gap-1 md:flex-row md:justify-between md:items-center mb-2"
                    >
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-sm md:text-lg font-medium">
                                    {{ item.item_name }}
                                </span>
                                {% if item.location %}
                                    <div
                                        class="{{
                                        cn(
                                            'bg-sub-green text-white rounded-full px-2 py-0.5',
                                            'flex items-center gap-0.5'
                                        )
                                        }}"
                                    >
                                        <span
                                            class="icon-[fluent-color--location-ripple-24]"
                                        >

                                        </span>
                                        <span
                                            class="hidden sm:block text-[10px] md:text-xs"
                                        >
                                            位置情報あり
                                        </span>
                                    </div>
                                {% endif %}
                            </div>
                            <div
                                class="text-xs md:text-sm text-gray-600 flex flex-wrap items-center gap-1"
                            >
                                <span
                                    class="text-sub-pink font-bold md:text-lg"
                                >
                                    {{ payer ? payer.member_name : '不明' }}
                                </span>
                                <span
                                    class="text-sm md:text-lg rotate-90 md:rotate-0"
                                >
                                    →
                                </span>
                                <span class="text-base text-gray-700">
                                    <div
                                        class="flex flex-wrap items-center gap-1"
                                    >
                                        {% for recipient in recipients %}
                                            <span
                                                class="text-sm font-bold md:text-lg text-blue-500"
                                            >
                                                {{ recipient }}
                                            </span>
                                            {% if not loop.last %}
                                                <span
                                                    class="text-sm md:text-lg"
                                                >
                                                    ,
                                                </span>
                                            {% endif %}
                                        {% endfor %}
                                    </div>
                                </span>
                            </div>
                        </div>
                    </div>
                    <div class="flex justify-between items-center">
                        <div
                            class="text-base md:text-2xl text-right md:text-right mt-1 md:mt-0 text-sub-pink"
                        >
                            ¥{{ item.amount|number_format(0, '.', ',') }}
                        </div>
                        {% if (item.participants|length) > 0 %}
                            {% set per_person =
                                (item.amount / (item.participants|length))
                                    |round(0, 'common')
                                    |number_format(0, '.', ',')
                            %}
                            <div class="text-xs md:text-sm text-gray-500 mt-2">
                                一人あたり: ¥{{ per_person }}
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
