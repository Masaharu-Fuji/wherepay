<div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
    <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🛍️</span>
        <h3>品目一覧</h3>
        <span
            class="ml-auto bg-purple-100 text-purple-800 px-3 py-1 rounded-full text-sm"
        >
            {{ room.items|length }}件
        </span>
    </div>

    {% if (room.items|length) == 0 %}
        <div class="text-center py-12">
            <div class="text-6xl mb-4">
                📝
            </div>
            <p class="text-gray-500">
                品目を追加してください
            </p>
        </div>
    {% else %}
        <div class="space-y-3">
            {% for item in room.items %}
                {% set payer = item.payer %}
                {% set recipients = [] %}
                {% for participant in item.participants %}
                    {% if participant.member %}
                        {% set recipients =
                            recipients|merge([participant.member.member_name])
                        %}
                    {% endif %}
                {% endfor %}
                <div
                    class="{{
                    cn(
                        'p-4',
                        'bg-gradient-to-r from-gray-50 to-purple-50',
                        'rounded-xl border border-gray-200',
                        'hover:shadow-md transition-shadow'
                    )
                    }}"
                >
                    <div class="flex justify-between items-start mb-2">
                        <div class="flex-1">
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-lg">
                                    {{ item.item_name }}
                                </span>
                                {% if item.location %}
                                    <span
                                        class="text-green-600 bg-green-100 px-2 py-1 rounded-full text-xs"
                                    >
                                        📍 位置情報あり
                                    </span>
                                {% endif %}
                            </div>
                            <div
                                class="text-sm text-gray-600 flex items-center gap-1"
                            >
                                <span class="text-purple-600">
                                    {{ payer ? payer.member_name : '不明' }}
                                </span>
                                <span>→</span>
                                <span class="text-blue-600">
                                    {{ recipients|join(', ') }}
                                </span>
                            </div>
                        </div>
                        <div class="text-2xl text-right ml-4 text-purple-600">
                            ¥{{ item.amount|number_format(0, '.', ',') }}
                        </div>
                    </div>
                    {% if (item.participants|length) > 0 %}
                        {% set per_person =
                            (item.amount / (item.participants|length))
                                |round(0, 'common')
                                |number_format(0, '.', ',')
                        %}
                        <div class="text-xs text-gray-500 mt-2">
                            一人あたり: ¥{{ per_person }}
                        </div>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
