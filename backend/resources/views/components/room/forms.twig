<div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-6">
    <div class="flex items-center gap-2 mb-4">
        <span class="text-2xl">🛍️</span>
        <h3 class="font-semibold">品目追加</h3>
    </div>
    <form
        method="POST"
        action="{{
        route(
            'rooms.items.store',
            {
                room: room.id
            }
        )
        }}"
        class="space-y-4"
        id="item-form"
    >
        <input type="hidden" name="_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="latitude" id="latitude" />
        <input type="hidden" name="longitude" id="longitude" />
        <input type="hidden" name="location_address" id="location_address" />

        <div>
            <label for="item_name" class="block mb-2 text-gray-700">
                品目名
            </label>
            <input
                id="item_name"
                name="item_name"
                placeholder="例: ランチ代、タクシー代"
                value="{{ old('item_name') }}"
                class="{{
                cn(
                    'w-full text-lg p-3',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-purple-500',
                    'focus:ring-4 focus:ring-purple-100',
                    'transition-all'
                )
                }}"
                required
            />
            {% if errors.has('item_name') %}
                <p class="mt-2 text-sm text-red-600">
                    {{ errors.first('item_name') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label for="amount" class="block mb-2 text-gray-700">
                金額（円）
            </label>
            <input
                id="amount"
                name="amount"
                type="number"
                min="1"
                value="{{ old('amount') }}"
                class="{{
                cn(
                    'w-full text-lg p-3',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-purple-500',
                    'focus:ring-4 focus:ring-purple-100',
                    'transition-all'
                )
                }}"
                required
            />
            {% if errors.has('amount') %}
                <p class="mt-2 text-sm text-red-600">
                    {{ errors.first('amount') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label for="payer_id" class="block mb-2 text-gray-700">
                支払者（誰が支払ったか）
            </label>
            <select
                id="payer_id"
                name="payer_id"
                class="{{
                cn(
                    'w-full text-lg p-3',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-purple-500',
                    'focus:ring-4 focus:ring-purple-100',
                    'transition-all',
                    'bg-white'
                )
                }}"
                required
            >
                <option value="">
                    選択してください
                </option>
                {% for member in room.members %}
                    <option
                        value="{{ member.id }}"
                        {{ old('payer_id') == member.id ? 'selected' : '' }}
                    >
                        {{ member.member_name }}
                    </option>
                {% endfor %}
            </select>
            {% if errors.has('payer_id') %}
                <p class="mt-2 text-sm text-red-600">
                    {{ errors.first('payer_id') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label class="block mb-2 text-gray-700">
                対象者（誰の分の支払いか）
            </label>
            <div
                class="{{
                cn(
                    'space-y-2 p-3',
                    'bg-gray-50 rounded-xl',
                    'border-2 border-gray-200',
                    'max-h-48 overflow-y-auto'
                )
                }}"
            >
                {% if (room.members|length) == 0 %}
                    <p class="text-gray-500 text-sm">
                        先にメンバーを追加してください
                    </p>
                {% else %}
                    {% for member in room.members %}
                        <label
                            class="{{
                            cn(
                                'flex items-center gap-3 p-3',
                                'bg-white rounded-lg cursor-pointer',
                                'hover:bg-blue-50 transition-colors',
                                'border border-gray-200'
                            )
                            }}"
                        >
                            <input
                                type="checkbox"
                                name="participant_ids[]"
                                value="{{ member.id }}"
                                class="{{
                                cn(
                                    'w-5 h-5',
                                    'text-purple-600 rounded',
                                    'focus:ring-2 focus:ring-purple-500'
                                )
                                }}"
                            />
                            <span class="text-lg">
                                {{ member.member_name }}
                            </span>
                        </label>
                    {% endfor %}
                {% endif %}
            </div>
            {% if errors.has('participant_ids') %}
                <p class="mt-2 text-sm text-red-600">
                    {{ errors.first('participant_ids') }}
                </p>
            {% endif %}
        </div>

        <div class="flex flex-col gap-3">
            <button
                type="button"
                onclick="getLocationForNextItem()"
                class="{{
                cn(
                    'w-full text-lg py-3',
                    'rounded-xl shadow-md',
                    'hover:shadow-lg transition-all',
                    'transform hover:scale-[1.02]',
                    'bg-gradient-to-r from-pink-500 to-pink-600 text-white',
                    'hover:from-pink-600 hover:to-pink-700'
                )
                }}"
            >
                📍 位置情報取得
            </button>
            <button
                type="submit"
                class="{{
                cn(
                    'w-full text-lg py-3',
                    'bg-gradient-to-r from-purple-500 to-purple-600 text-white',
                    'rounded-xl',
                    'hover:from-purple-600 hover:to-purple-700',
                    'shadow-lg transition-all'
                )
                }}"
            >
                追加
            </button>
        </div>
    </form>
</div>
