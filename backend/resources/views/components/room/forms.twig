<div class="bg-white rounded-2xl border border-gray-200 shadow-lg p-2 md:p-6">
    <div class="flex items-center gap-2 mb-4">
        <span class="icon-[fluent-color--drafts-20] w-10 h-10"></span>
        <h3 class="font-semibold text-xs md:text-sm">品目追加</h3>
    </div>
    <form
        method="POST"
        action="{{
        route(
            'rooms.items.store',
            {
                room: room.id
            }
        )
        }}"
        class="space-y-2 md:space-y-4"
        id="item-form"
    >
        <input type="hidden" name="_token" value="{{ csrf_token() }}" />
        <input type="hidden" name="latitude" id="latitude" />
        <input type="hidden" name="longitude" id="longitude" />
        <input type="hidden" name="location_address" id="location_address" />

        <div>
            <label
                for="item_name"
                class="block text-xs md:text-sm mb-2 text-gray-700"
            >
                品目名
            </label>
            <input
                id="item_name"
                name="item_name"
                placeholder="例: ランチ代、タクシー代"
                value="{{ old('item_name') }}"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-sub-pink',
                    'focus:ring-4 focus:ring-sub-pink-100',
                    'transition-all'
                )
                }}"
                required
            />
            {% if errors.has('item_name') %}
                <p class="mt-2 text-sm text-sub-pink">
                    {{ errors.first('item_name') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label
                for="amount"
                class="block text-xs md:text-sm mb-2 text-gray-700"
            >
                金額（円）
            </label>
            <input
                id="amount"
                name="amount"
                type="number"
                min="1"
                value="{{ old('amount') }}"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-sub-pink',
                    'focus:ring-4 focus:ring-sub-pink-100',
                    'transition-all'
                )
                }}"
                required
            />
            {% if errors.has('amount') %}
                <p class="mt-2 text-sm text-sub-pink">
                    {{ errors.first('amount') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label
                for="payer_id"
                class="block text-xs md:text-sm mb-2 text-gray-700"
            >
                支払者（誰が支払ったか）
            </label>
            <select
                id="payer_id"
                name="payer_id"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'border-2 border-gray-200 rounded-xl',
                    'focus:outline-none focus:border-sub-pink',
                    'focus:ring-4 focus:ring-sub-pink-100',
                    'transition-all',
                    'bg-white'
                )
                }}"
                required
            >
                <option value="">
                    選択してください
                </option>
                {% for member in room.members %}
                    <option
                        value="{{ member.id }}"
                        {{ old('payer_id') == member.id ? 'selected' : '' }}
                    >
                        {{ member.member_name }}
                    </option>
                {% endfor %}
            </select>
            {% if errors.has('payer_id') %}
                <p class="mt-2 text-sm text-sub-pink">
                    {{ errors.first('payer_id') }}
                </p>
            {% endif %}
        </div>

        <div>
            <label class="block text-xs md:text-sm mb-2 text-gray-700">
                対象者（誰の分の支払いか）
            </label>
            <div
                class="{{
                cn(
                    'space-y-2 p-2 md:p-3',
                    'bg-gray-50 rounded-xl',
                    'border-2 border-gray-200',
                    'max-h-48 overflow-y-auto'
                )
                }}"
            >
                {% if (room.members|length) == 0 %}
                    <p class="text-gray-500 text-sm">
                        先にメンバーを追加してください
                    </p>
                {% else %}
                    {% for member in room.members %}
                        <label
                            class="{{
                            cn(
                                'flex items-center gap-3 p-2 md:p-3',
                                'bg-white rounded-lg cursor-pointer',
                                'hover:bg-primary-50 transition-colors',
                                'border border-gray-200'
                            )
                            }}"
                        >
                            <input
                                type="checkbox"
                                name="participant_ids[]"
                                value="{{ member.id }}"
                                class="{{
                                cn(
                                    'w-5 h-5',
                                    'text-sub-pink rounded',
                                    'focus:ring-2 focus:ring-sub-pink'
                                )
                                }}"
                            />
                            <span class="text-sm md:text-lg">
                                {{ member.member_name }}
                            </span>
                        </label>
                    {% endfor %}
                {% endif %}
            </div>
            {% if errors.has('participant_ids') %}
                <p class="mt-2 text-sm text-sub-pink">
                    {{ errors.first('participant_ids') }}
                </p>
            {% endif %}
        </div>

        <div class="flex flex-col gap-3">
            <button
                type="button"
                onclick="location()"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'rounded-xl shadow-md',
                    'hover:shadow-lg transition-all',
                    'transform hover:scale-[1.02]',
                    'bg-gradient-to-r from-sub-pink to-sub-pink-hover text-white',
                    'hover:opacity-90',
                    'flex items-center justify-center gap-1'
                )
                }}"
            >
                <span class="icon-[fluent-color--location-ripple-24] w-5 h-5">

                </span>
                <span class="text-sm md:text-xl">位置情報取得</span>
            </button>
            <button
                type="submit"
                class="{{
                cn(
                    'w-full text-sm md:text-lg p-2',
                    'bg-gradient-to-r from-primary to-sub-pink text-white',
                    'rounded-xl',
                    'hover:from-primary-hover hover:to-sub-pink-hover',
                    'shadow-lg transition-all',
                    'flex items-center justify-center gap-1'
                )
                }}"
            >
                <span class="icon-[fluent-color--gift-24] w-5 h-5"></span>
                <span class="text-sm md:text-xl">追加</span>
            </button>
        </div>
    </form>
</div>
